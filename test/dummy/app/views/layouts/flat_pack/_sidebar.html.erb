<%= render FlatPack::Sidebar::Component.new(side: sidebar_side) do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "RS",
      title: "Accessible",
      subtitle: "Recording Studio"
    ) %>
  <% end %>

  <% sidebar.items do %>
    <nav class="py-4 space-y-1" aria-label="Main navigation">
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Home",
        href: "/",
        icon: :home
      ) %>
      <% if recording_studio_accessible_docs_visible? %>
        <%= render FlatPack::Sidebar::Item::Component.new(
          label: "Overview",
          href: "/recording_studio_accessible/overview",
          icon: :question
        ) %>
        <%= render FlatPack::Sidebar::Item::Component.new(
          label: "Methods",
          href: "/recording_studio_accessible/methods",
          icon: :menu
        ) %>
        <%= render FlatPack::Sidebar::Item::Component.new(
          label: "User invites",
          href: "/recording_studio_accessible/user_invites",
          icon: :user
        ) %>
        <%= render FlatPack::Sidebar::Item::Component.new(
          label: "Email template",
          href: "/recording_studio_accessible/email_template",
          icon: :mail
        ) %>
      <% end %>
    </nav>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Sign out",
        href: main_app.destroy_user_session_path,
        icon: :lock,
        class: "mx-0",
        data: { turbo_method: :delete }
      ) %>
    <% end %>
  <% end %>
<% end %>
