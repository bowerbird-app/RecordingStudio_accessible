<div class="mx-auto w-full max-w-6xl">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Recording Studio Accessible Demo",
    subtitle: "Demo of how access works",
    variant: :h1
  ) %>

  <div class="mt-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: @workspace ? "Workspace: #{@workspace.name}" : "Workspace",
      subtitle: "People with workspace access",
      anchor_link: true,
      anchor_id: "workspace-access"
    ) %>

    <% if @root_recording %>
      <div class="mb-6">
        <%= render FlatPack::Button::Component.new(
          text: "Manage workspace access",
          style: :primary,
          size: :md,
          url: recording_studio_accessible.recording_accesses_path(@root_recording)
        ) %>
      </div>
    <% end %>

    <%= render FlatPack::ChipGroup::Component.new(class: "mb-6") do %>
      <% @workspace_access_rows.each do |access_row| %>
        <%= render FlatPack::Chip::Component.new(
          text: "#{access_row[:email]} (#{access_row[:role]})",
          type: :link,
          href: user_path(access_row[:user]),
          style: :default,
          size: :md
        ) %>
      <% end %>
    <% end %>

    <%= render FlatPack::SectionTitle::Component.new(
      title: "Folders and pages",
      anchor_link: true,
      anchor_id: "folders-and-pages"
    ) %>

    <%= render FlatPack::Grid::Component.new(cols: 2, gap: :md, align: :start, class: "w-full") do %>
      <% @demo_sections.each do |section| %>
        <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
          <% card.body(class: "grid gap-3 justify-items-start") do %>
            <h3 class="text-lg font-semibold leading-tight text-slate-900"><%= section[:folder].name %></h3>
            <%= render FlatPack::Badge::Component.new(text: section[:folder].class.name, style: :info, size: :sm) %>
            <% folder_direct_access_count = @direct_access_counts_by_recording_id.fetch(section[:folder_recording]&.id, 0) %>
            <%= render FlatPack::Badge::Component.new(
              text: pluralize(folder_direct_access_count, "person") + " with direct access",
              style: :default,
              size: :sm
            ) %>
            <% if section[:folder_recording] %>
              <%= render FlatPack::Button::Component.new(
                text: "Access",
                style: :default,
                size: :sm,
                url: recording_studio_accessible.recording_accesses_path(section[:folder_recording])
              ) %>
            <% end %>
          <% end %>
        <% end %>

        <% section[:pages].each do |page_section| %>
          <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
            <% card.body(class: "grid gap-3 justify-items-start") do %>
              <h3 class="text-lg font-semibold leading-tight text-slate-900"><%= page_section[:page].title %></h3>
              <%= render FlatPack::Badge::Component.new(text: page_section[:page].class.name, style: :default, size: :sm) %>
              <% page_direct_access_count = @direct_access_counts_by_recording_id.fetch(page_section[:page_recording]&.id, 0) %>
              <%= render FlatPack::Badge::Component.new(
                text: pluralize(page_direct_access_count, "person") + " with direct access",
                style: :default,
                size: :sm
              ) %>
              <% if page_section[:page_recording] %>
                <%= render FlatPack::Button::Component.new(
                  text: "Access",
                  style: :default,
                  size: :sm,
                  url: recording_studio_accessible.recording_accesses_path(page_section[:page_recording])
                ) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
