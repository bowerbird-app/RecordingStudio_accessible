<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: @workspace&.name || "Recording Studio Accessible demo",
    subtitle: "This dummy app shows access functionality arriving through the separately installed Recording Studio Accessible addon.",
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-2">
    <%= render FlatPack::Badge::Component.new(text: "Addon gem in Gemfile", style: :info, size: :sm) %>
    <%= render FlatPack::Badge::Component.new(text: "Mode: #{@integration_mode}", style: (@integration_mode == :addon ? :success : :warning), size: :sm) %>
    <%= render FlatPack::Badge::Component.new(text: "RecordingStudio mounted", style: :success, size: :sm) %>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(320px,1fr)]">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Access flow demo",
          subtitle: "Seeded roles resolved through RecordingStudio::Services::AccessCheck.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <dl class="space-y-4 text-sm leading-6 text-[var(--surface-content-color)]">
          <div>
            <dt class="text-[var(--surface-muted-content-color)]">Workspace</dt>
            <dd class="font-medium"><%= @workspace&.name || "Not seeded" %></dd>
          </div>
          <div>
            <dt class="text-[var(--surface-muted-content-color)]">Root recording</dt>
            <dd class="font-mono text-xs"><%= @root_recording&.id || "Missing" %></dd>
          </div>
          <% @access_rows.each do |row| %>
            <div>
              <dt class="text-[var(--surface-muted-content-color)]"><%= row[:label] %></dt>
              <dd class="font-medium">role=<%= row[:role] || "none" %>, allowed=<%= row[:allowed] %></dd>
            </div>
          <% end %>
        </dl>
      <% end %>
    <% end %>

    <div class="flex flex-col gap-6">
      <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
        <% card.header do %>
          <%= render FlatPack::PageTitle::Component.new(
            title: "Separate installation",
            subtitle: "Why this proves access is addon-owned.",
            variant: :h3,
            class: "mb-0 pb-0"
          ) %>
        <% end %>

        <% card.body do %>
          <ol class="space-y-3 text-sm leading-6 list-decimal pl-5">
            <li>The host app installs <code>recording_studio_accessible</code> separately from <code>recording_studio</code>.</li>
            <li>The addon is mounted at <code>/recording_studio_accessible</code>.</li>
            <li>If the gem is removed, the addon route and this seeded access demo disappear with it.</li>
          </ol>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
        <% card.header do %>
          <%= render FlatPack::PageTitle::Component.new(
            title: "Useful routes",
            subtitle: "Quick links for the host app and addon pages.",
            variant: :h3,
            class: "mb-0 pb-0"
          ) %>
        <% end %>

        <% card.body do %>
          <div class="space-y-3 text-sm">
            <p><strong>App home:</strong> <code>/</code></p>
            <p><strong>Recording Studio mount:</strong> <code>/recording_studio</code></p>
            <p><strong>Addon mount:</strong> <code>/recording_studio_accessible</code></p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
