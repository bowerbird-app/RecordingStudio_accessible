<p>Hello <%= @actor.respond_to?(:email) ? @actor.email : "there" %>,</p>

<p><%= @manager_actor_display_name %> granted you <strong><%= @role.humanize.downcase %></strong> access<%= @recording_label.present? ? " to #{@recording_label}" : "" %>.</p>

<% if @access_url.present? %>
  <p><a href="<%= @access_url %>">Open the shared item</a></p>
<% end %>
