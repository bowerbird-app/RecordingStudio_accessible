<%= render FlatPack::Breadcrumb::Component.new(class: "mb-4") do |breadcrumb| %>
  <% breadcrumb.item(text: "Back", href: recording_accesses_path(@recording), icon: "chevron-left") %>
<% end %>

<%= render FlatPack::PageTitle::Component.new(
  title: "Add boundary",
  subtitle: @recording_label,
  variant: :h1
) %>

<%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
  <% card.body(class: "grid gap-4 justify-items-start") do %>
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Before you add a boundary",
      subtitle: "This gives this folder its own access rules.",
      anchor_link: true,
      anchor_id: "how-boundaries-work"
    ) %>

    <div class="grid gap-3 text-sm text-[var(--surface-content-color)]">
      <p>
        People who can see the parent area will not automatically see everything inside this folder.
      </p>
      <p>
        This boundary requires Edit access. If someone needs to see or work in this folder and does not already have enough access, you can add them here separately.
      </p>
      <p>
        You can remove this later from the Manage access page.
      </p>
    </div>

    <%= form_with url: recording_boundary_path(@recording), method: :post do %>
      <%= render FlatPack::Button::Component.new(
        text: "Confirm add boundary",
        style: :primary,
        size: :md,
        type: "submit"
      ) %>
    <% end %>
  <% end %>
<% end %>