<div class="mx-auto w-full max-w-6xl">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Recording Studio Accessible Demo",
    subtitle: "Optional access-control addon",
    variant: :h1
  ) %>

  <div class="mt-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Access check snapshot",
      subtitle: "Demo of how access works for the seeded workspace",
      anchor_link: true,
      anchor_id: "access-check-snapshot"
    ) %>

    <div class="grid gap-3">
      <p><strong>Integration mode:</strong> <%= @integration_mode %></p>
      <p><strong>Workspace:</strong> <%= @workspace&.name || "Not available" %></p>
      <p><strong>Root recording:</strong> <%= @root_recording&.id || "Not available" %></p>
    </div>

    <%= render FlatPack::SectionTitle::Component.new(
      title: "People with workspace access",
      anchor_link: true,
      anchor_id: "people-with-workspace-access"
    ) %>

    <div class="grid gap-3">
      <% @access_rows.each do |row| %>
        <p>
          <strong><%= row[:label] %></strong>
          (<%= row[:role] || "none" %>)
          -
          <%= row[:allowed] ? "Allowed" : "Denied" %>
        </p>
      <% end %>
    </div>
  </div>
</div>
