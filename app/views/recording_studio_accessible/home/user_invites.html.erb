<div class="mx-auto w-full max-w-6xl">
  <%= render FlatPack::PageTitle::Component.new(
    title: "User invites",
    subtitle: "How missing emails are resolved during access grants",
    variant: :h1
  ) %>

  <div class="mt-6 grid gap-8">
    <section>
      <%= render FlatPack::SectionTitle::Component.new(
        title: "What happens when a user is not found",
        anchor_link: true,
        anchor_id: "missing-user"
      ) %>

      <%= render FlatPack::Grid::Component.new(cols: 2, gap: :md, align: :start, class: "w-full") do %>
        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body(class: "grid gap-3 justify-items-start") do %>
            <%= render FlatPack::Badge::Component.new(text: "Default", style: :default, size: :sm) %>
            <p class="text-base leading-7 text-[var(--surface-content-color)]">
              If you do nothing, the addon keeps the current validation error and the form shows
              <strong>User with email ... was not found</strong>.
            </p>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
          <% card.body(class: "grid gap-3 justify-items-start") do %>
            <%= render FlatPack::Badge::Component.new(text: "Dummy app", style: :info, size: :sm) %>
            <p class="text-base leading-7 text-[var(--surface-content-color)]">
              This dummy app overrides that default in its initializer. It normalizes the email,
              rejects blank input, creates the user when needed, and returns <strong>:created</strong>
              so the grant finishes in the same request.
            </p>
          <% end %>
        <% end %>
      <% end %>
    </section>

    <section>
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Statuses you can return",
        anchor_link: true,
        anchor_id: "statuses"
      ) %>

      <%= render FlatPack::List::Component.new(divider: true, class: "w-full") do %>
        <% @invite_status_rows.each do |row| %>
          <%= render FlatPack::List::Item.new(class: "py-3 px-0") do %>
            <div class="flex w-full items-start justify-between gap-4">
              <p class="min-w-0 flex-1 text-base leading-7 text-[var(--surface-content-color)]"><%= row[:body] %></p>
              <%= render FlatPack::Badge::Component.new(text: row[:title], style: row[:badge_style], size: :sm) %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </section>

    <section>
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Setup patterns",
        subtitle: "Choose one handler shape based on what your host app should do next",
        anchor_link: true,
        anchor_id: "setup-patterns"
      ) %>

      <%= render FlatPack::Grid::Component.new(cols: 1, gap: :md, class: "w-full") do %>
        <% @invite_setup_examples.each do |example| %>
          <section>
            <%= render FlatPack::SectionTitle::Component.new(
              title: example[:title],
              subtitle: example[:body],
              anchor_link: true,
              anchor_id: example[:title].parameterize
            ) %>

            <%= render FlatPack::CodeBlock::Component.new(
              code: example[:code],
              separated: false
            ) %>
          </section>
        <% end %>
      <% end %>
    </section>
  </div>
</div>